import sheetUrl from '../../assets/sprites/03000_magicienne.png'

// Sheet: 320×256 — 10 cols × 8 rows at 32×32 px per frame
// Row layout: 0=down, 1=left, 2=right, 3=up
// Walk cycle: col 0 (left-step), col 1 (stand), col 2 (right-step)
const FRAME_W = 32
const FRAME_H = 32
const ROW = { down: 0, right: 1, up: 2, left: 3 }
// Alternates between left-step and right-step (skip standing col 1)
const WALK_COLS = [0, 2]

const sheet = new Image()
sheet.src = sheetUrl

export function drawWarriorSprite(ctx, x, y, facing, frame, phase) {
  if (!sheet.complete || sheet.naturalWidth === 0) return
  const row = ROW[facing] ?? ROW.down
  const col = WALK_COLS[frame & 1]
  const bob = (frame & 1) ? 1 : 0

  // Blinking purple halo beneath sprite
  const glow = 0.18 + Math.sin(phase * 2.3) * 0.12
  ctx.save()
  ctx.globalAlpha = glow
  ctx.fillStyle = '#c040ff'
  ctx.beginPath()
  ctx.ellipse(Math.floor(x) + 8, Math.floor(y) + 22, 10, 4, 0, 0, Math.PI * 2)
  ctx.fill()
  ctx.restore()

  ctx.save()
  ctx.imageSmoothingEnabled = false
  ctx.drawImage(
    sheet,
    col * FRAME_W, row * FRAME_H, FRAME_W, FRAME_H,
    Math.floor(x) - 8, Math.floor(y) + bob - 8, FRAME_W, FRAME_H
  )
  ctx.restore()
}


